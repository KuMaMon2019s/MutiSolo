#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
mineru_bin="$repo_root/.venv-mineru/bin/mineru"

if [[ ! -x "$mineru_bin" ]]; then
  echo "MinerU is not installed at $mineru_bin" >&2
  echo "See docs/mineru-native.md for native setup steps." >&2
  exit 1
fi

if [[ $# -lt 1 ]]; then
  echo "Usage: scripts/mineru-parse <file-or-dir> [output-dir] [extra mineru args...]" >&2
  exit 1
fi

input_path="$1"
shift

output_dir="${1:-$repo_root/.openclaw/mineru}"
if [[ $# -gt 0 ]]; then
  shift
fi

backend="${MINERU_BACKEND:-pipeline}"
method="${MINERU_METHOD:-auto}"
formula="${MINERU_FORMULA:-false}"

cmd=(
  "$mineru_bin"
  -p "$input_path"
  -o "$output_dir"
  -b "$backend"
  -m "$method"
  -f "$formula"
)

if [[ -n "${MINERU_API_URL:-}" ]]; then
  cmd+=(--api-url "$MINERU_API_URL")
fi

cmd+=("$@")

exec "${cmd[@]}"
